# Copy this file to .env and fill in your values before starting the server.

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/caminos-compass

# JWT secret — change this to a long random string in production
JWT_SECRET=replace_with_a_long_random_secret

# JWT expiry (e.g. 1h, 7d)
JWT_EXPIRES_IN=1h

# Port the Express server listens on
PORT=5000

# Allowed origin for CORS (your React dev server)
CLIENT_ORIGIN=http://localhost:3000

# Used only by scripts/createAdmin.js
ADMIN_FIRST=Admin
ADMIN_LAST=User
ADMIN_EMAIL=admin@caminos.edu
ADMIN_PASSWORD=ChangeThisPassword

# Gemini API key for lesson plan generation and writing sample evaluation
GEMINI_API_KEY=your_gemini_api_key_here

# Optional Gemini tuning. The service automatically retries transient
# 429/5xx errors with exponential backoff and falls back to the secondary
# model if the primary keeps failing.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
GEMINI_MAX_ATTEMPTS=3
GEMINI_BACKOFF_MS=600
