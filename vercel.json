{
  "version": 2,
  "installCommand": "npm install && cd my-app && npm install",
  "buildCommand": "cd my-app && npm run build",
  "outputDirectory": "my-app/build",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
